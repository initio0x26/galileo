use either::Either;
use galileo_mvt::{MvtFeature, MvtGeometry, MvtLayer, MvtPolygon, MvtTile};
use galileo_types::cartesian::{CartesianPoint2d, CartesianPoint3d, Point2, Point3, Rect, Vector2};
use galileo_types::impls::{ClosedContour, Polygon};
use galileo_types::{Contour, MultiContour, MultiPolygon, Polygon as PolygonTrait};
use num_traits::ToPrimitive;
use regex::Regex;

use crate::TileSchema;
use crate::error::GalileoError;
use crate::expr::ExprView;
use crate::layer::vector_tile_layer::style::{
    StyleRule, VectorTileLabelSymbol, VectorTileLineLabelSymbol, VectorTileStyle,
};
use crate::render::point_paint::{PointPaint, PointShape};
use crate::render::render_bundle::RenderBundle;
use crate::render::{LinePaint, PolygonPaint};
use crate::tile_schema::TileIndex;

/// Data processor that decodes vector tiles.
pub struct VtProcessor {}

/// Vector tiles decoding context.
pub struct VectorTileDecodeContext {
    /// Index of the tile.
    pub index: TileIndex,
    /// Vector tile layer style.
    pub style: VectorTileStyle,
    /// Vector tile layer tile schema.
    pub tile_schema: TileSchema,
    /// Render bundle to add render primitives to.
    pub bundle: RenderBundle,
}

fn get_rule_layers<'a>(
    rule: &StyleRule,
    all_rules: &'a [StyleRule],
    layers: &'a [MvtLayer],
) -> impl Iterator<Item = &'a MvtLayer> {
    match &rule.layer_name {
        Some(layer_name) => Either::Left(layers.iter().find(|l| &l.name == layer_name).into_iter()),
        None => Either::Right(layers.iter().filter(|l| {
            !all_rules
                .iter()
                .any(|r| r.layer_name.as_ref() == Some(&l.name))
        })),
    }
}

impl VtProcessor {
    /// line label helper
    fn format_line_label(
        label_symbol: &VectorTileLineLabelSymbol,
        feature: &MvtFeature,
        view: ExprView,
    ) -> Option<(String, crate::render::text::TextStyle, f32)> {
        let re = Regex::new(r"\{(?<name>.+)}").ok()?;
        let mut text = label_symbol.pattern.to_string();
        for m in re.captures_iter(&label_symbol.pattern) {
            let prop_name = &m["name"];
            let prop = feature
                .properties
                .get(prop_name)
                .map(|v| v.to_string())
                .unwrap_or_default();
            text = text.replace(&format!("{{{prop_name}}}"), &prop);
        }
        let style = label_symbol.text_style.clone().get_value(feature, view)?;
        let offset = label_symbol.line_offset_px.eval(feature, view)? as f32;
        Some((text, style, offset))
    }

    /// Pre-render the given tile into the given `bundle`.
    pub fn prepare(
        mvt_tile: &MvtTile,
        bundle: &mut RenderBundle,
        index: TileIndex,
        style: &VectorTileStyle,
        tile_schema: &TileSchema,
        view_resolution: f64,
    ) -> Result<(), GalileoError> {
        let lod_resolution = tile_schema
            .lod_resolution(index.z)
            .ok_or_else(|| {
                GalileoError::Generic(format!(
                    "cannot get lod resolution for lod {}",
                    index.z
                ))
            })?;

        let tile_resolution = lod_resolution * tile_schema.tile_width() as f64;
        let width = tile_schema.tile_width() as f64;
        let height = tile_schema.tile_height() as f64;

        // tile-local bbox in world units
        let bbox = Rect::new(0.0, 0.0, width * lod_resolution, -height * lod_resolution);

        let bounds = Polygon::new(
            ClosedContour::new(vec![
                Point3::new(bbox.x_min(), bbox.y_min(), 0.0),
                Point3::new(bbox.x_min(), bbox.y_max(), 0.0),
                Point3::new(bbox.x_max(), bbox.y_max(), 0.0),
                Point3::new(bbox.x_max(), bbox.y_min(), 0.0),
            ]),
            vec![],
        );

        bundle.world_set.clip_area(&bounds);

        for rule in &style.rules {
            if rule.max_resolution.is_some_and(|v| v < lod_resolution) {
                continue;
            }
            if rule.min_resolution.is_some_and(|v| v > lod_resolution) {
                continue;
            }

            for layer in get_rule_layers(rule, &style.rules, &mvt_tile.layers) {
                for feature in &layer.features {
                    if !rule.applies(feature, tile_resolution, index.z) {
                        continue;
                    }

                    let expr_view_lod = ExprView {
                        resolution: lod_resolution,
                        z_index: Some(index.z),
                    };

                    // untuk text/label lebih baik pakai view_resolution (screen-driven)
                    let expr_view_view = ExprView {
                        resolution: view_resolution,
                        z_index: Some(index.z),
                    };

                    match &feature.geometry {
                        MvtGeometry::Point(points) => {
                            let Some(paint) = Self::get_point_symbol(rule, feature, expr_view_lod)
                            else {
                                continue;
                            };

                            for point in points {
                                let position = Self::transform_point(point, tile_resolution);
                                match &paint.shape {
                                    PointShape::Label { text, style } => {
                                        if !text.is_empty() {
                                            bundle.add_label(
                                                &position,
                                                text,
                                                style,
                                                Vector2::default(),
                                                false,
                                            );
                                        }
                                    }
                                    _ => {
                                        bundle.add_point(&position, &paint, lod_resolution);
                                    }
                                }
                            }
                        }

                        MvtGeometry::LineString(contours) => {
                            // draw line stroke
                            if let Some(paint) = Self::get_line_symbol(rule, feature, expr_view_lod) {
                                for contour in contours.contours() {
                                    let pts: Vec<Point3> = contour
                                        .iter_points()
                                        .map(|p| Self::transform_point(&p, tile_resolution))
                                        .collect();
                                    let geom = galileo_types::impls::Contour::new(pts, false);
                                    bundle.add_line(&geom, &paint, lod_resolution);
                                }
                            }

                            // draw line label
                            if let Some(line_label) = rule.symbol.line_label() {
                                if let Some((text, text_style, line_offset_px)) =
                                    Self::format_line_label(line_label, feature, expr_view_view)
                                {
                                    if text.is_empty() || text_style.font_size < 12.0 {
                                        continue;
                                    }

                                    let min_distance_px = line_label
                                        .min_distance_px
                                        .eval(feature, expr_view_view)
                                        .unwrap_or(0.0) as f32;

                                    let repeat = line_label.repeat;
                                    let keep_upright = line_label.keep_upright;

                                    let mut label_pts: Vec<Vec<Point3>> = Vec::new();

                                    if repeat {
                                        // ✅ repeat: semua contour
                                        for contour in contours.contours() {
                                            let pts: Vec<Point3> = contour
                                                .iter_points()
                                                .map(|p| Self::transform_point(&p, tile_resolution))
                                                .collect();

                                            if pts.len() >= 2 {
                                                label_pts.push(pts);
                                            }
                                        }
                                    } else {
                                        // ✅ repeat:false: pilih contour TERPANJANG
                                        let mut best_pts: Option<Vec<Point3>> = None;
                                        let mut best_len_px: f32 = 0.0;

                                        for contour in contours.contours() {
                                            let pts: Vec<Point3> = contour
                                                .iter_points()
                                                .map(|p| Self::transform_point(&p, tile_resolution))
                                                .collect();

                                            if pts.len() < 2 {
                                                continue;
                                            }

                                            let len_px = Self::polyline_len_px(&pts, view_resolution);
                                            if len_px > best_len_px {
                                                best_len_px = len_px;
                                                best_pts = Some(pts);
                                            }
                                        }

                                        let Some(best_pts) = best_pts else { continue; };

                                        if best_len_px < min_distance_px.max(0.0) {
                                            continue;
                                        }

                                        // anti-duplicate antar tile
                                        let pad_px = min_distance_px.max(256.0); 
                                        let pad_world = view_resolution * (pad_px as f64);
                                        if let Some(mid) = Self::midpoint_by_world_length(&best_pts) {
                                            if !Self::inside_bbox_with_padding(&mid, bbox, pad_world) {
                                                continue;
                                            }
                                        }
                                        else {
                                            continue;
                                        }
                                        
                                        
                                        let near_edge = |p: &Point3| !Self::inside_bbox_with_padding(p, bbox, pad_world);
                                        if near_edge(&best_pts[0]) || near_edge(best_pts.last().unwrap()) {
                                            continue;
                                        }


                                        label_pts.push(best_pts);
                                    }

                                    // ✅ SATU loop render (tidak duplikat)
                                    for pts in label_pts {
                                        let geom = galileo_types::impls::Contour::new(pts, false);


                                    log::warn!(
                                    "LINE_LABEL draw: z={} layer={} text='{}' repeat={} minDistPx={}",
                                    index.z, layer.name, text, repeat, min_distance_px
                                    );

                                        bundle.world_set.add_label_on_path(
                                            &geom,
                                            &text,
                                            &text_style,
                                            line_offset_px,
                                            repeat,
                                            min_distance_px,
                                            keep_upright,
                                            view_resolution,
                                        );
                                    }

                                    
                                }

                            
                            

                            

                            }




                        }

                        MvtGeometry::Polygon(polygons) => {
                            if let Some(paint) =
                                Self::get_polygon_symbol(rule, feature, expr_view_lod)
                            {
                                for polygon in polygons.polygons() {
                                    bundle.add_polygon(
                                        &Self::transform_polygon(polygon, tile_resolution),
                                        &paint,
                                        lod_resolution,
                                    );
                                }
                            }
                        }
                    }
                }
            }
        }

        Ok(())
    }

    fn get_point_symbol<'a>(
        rule: &'a StyleRule,
        feature: &MvtFeature,
        view: ExprView,
    ) -> Option<PointPaint<'a>> {
        rule.symbol
            .point()
            .and_then(|symbol| symbol.to_paint(feature, view))
            .or_else(|| {
                rule.symbol
                    .label()
                    .and_then(|symbol| Self::format_label(symbol, feature, view))
            })
    }

    fn format_label<'a>(
        label_symbol: &VectorTileLabelSymbol,
        feature: &MvtFeature,
        view: ExprView,
    ) -> Option<PointPaint<'a>> {
        let re = Regex::new(r"\{(?<name>.+)}").ok()?;
        let mut text = label_symbol.pattern.to_string();
        for m in re.captures_iter(&label_symbol.pattern) {
            let prop_name = &m["name"];
            let prop = feature
                .properties
                .get(prop_name)
                .map(|v| v.to_string())
                .unwrap_or_default();
            text = text.replace(&format!("{{{prop_name}}}"), &prop);
        }
        Some(PointPaint::label_owned(
            text,
            label_symbol.text_style.clone().get_value(feature, view)?,
        ))
    }

    fn get_line_symbol<'a>(
        rule: &'a StyleRule,
        feature: &'a MvtFeature,
        view: ExprView,
    ) -> Option<LinePaint<'a>> {
        rule.symbol.line().and_then(|s| s.to_paint(feature, view))
    }

    fn get_polygon_symbol(
        rule: &StyleRule,
        feature: &MvtFeature,
        view: ExprView,
    ) -> Option<PolygonPaint> {
        rule.symbol
            .polygon()
            .and_then(|s| s.to_paint(feature, view))
    }

    fn transform_polygon(mvt_polygon: &MvtPolygon, tile_resolution: f64) -> Polygon<Point3> {
        let cast = |p| Self::transform_point(&p, tile_resolution);
        Polygon {
            outer_contour: ClosedContour::new(
                mvt_polygon
                    .outer_contour()
                    .iter_points()
                    .map(&cast)
                    .collect(),
            ),
            inner_contours: mvt_polygon
                .inner_contours()
                .map(|c| ClosedContour::new(c.iter_points().map(&cast).collect()))
                .collect(),
        }
    }

    fn transform_point<Num: num_traits::Float + ToPrimitive>(
        p_in: &impl CartesianPoint2d<Num = Num>,
        tile_resolution: f64,
    ) -> Point3 {
        let x = p_in.x().to_f64().expect("double overflow") * tile_resolution;
        let y = -p_in.y().to_f64().expect("double overflow") * tile_resolution;
        Point3::new(x, y, 0.0)
    }

    // ===== helpers for anti-duplicate (tile ownership) =====
    fn midpoint_by_world_length(pts: &[Point3]) -> Option<Point3> {
        if pts.len() < 2 {
            return None;
        }

        let mut seg_lens = Vec::with_capacity(pts.len() - 1);
        let mut total = 0.0_f64;

        for i in 0..pts.len() - 1 {
            let dx = pts[i + 1].x() - pts[i].x();
            let dy = pts[i + 1].y() - pts[i].y();
            let len = (dx * dx + dy * dy).sqrt();
            if len <= 1e-9 {
                seg_lens.push(0.0);
                continue;
            }
            seg_lens.push(len);
            total += len;
        }

        if total <= 1e-9 {
            return None;
        }

        let target = total * 0.5;
        let mut acc = 0.0_f64;

        for i in 0..seg_lens.len() {
            let len = seg_lens[i];
            if len <= 1e-9 {
                continue;
            }
            if acc + len >= target {
                let t = (target - acc) / len;
                let x = pts[i].x() + (pts[i + 1].x() - pts[i].x()) * t;
                let y = pts[i].y() + (pts[i + 1].y() - pts[i].y()) * t;
                return Some(Point3::new(x, y, 0.0));
            }
            acc += len;
        }

        Some(*pts.last().unwrap())
    }

    fn inside_bbox_with_padding(p: &Point3, bbox: Rect<f64>, pad_world: f64) -> bool {
        let xmin = bbox.x_min().min(bbox.x_max()) + pad_world;
        let xmax = bbox.x_min().max(bbox.x_max()) - pad_world;
        let ymin = bbox.y_min().min(bbox.y_max()) + pad_world;
        let ymax = bbox.y_min().max(bbox.y_max()) - pad_world;

        p.x() >= xmin && p.x() <= xmax && p.y() >= ymin && p.y() <= ymax
    }

    #[inline]

fn contour_to_pts<C, P>(
    contour: &C,
    tile_resolution: f64,
) -> Vec<Point3>
where
    C: galileo_types::contour::Contour<Point = P>,
    P: galileo_types::cartesian::CartesianPoint3d<Num = f64>,
{
    contour
        .iter_points()
        .map(|p| Self::transform_point(&Point2::new(p.x(), p.y()), tile_resolution))
        .collect()
}


#[inline]
fn polyline_len_px(pts: &[Point3], view_resolution: f64) -> f32 {
    if pts.len() < 2 {
        return 0.0;
    }

    let mut total_world = 0.0_f64;
    for i in 0..pts.len() - 1 {
        let dx = pts[i + 1].x() - pts[i].x();
        let dy = pts[i + 1].y() - pts[i].y();
        total_world += (dx * dx + dy * dy).sqrt();
    }

    (total_world / view_resolution.max(1e-12)) as f32
}


}




